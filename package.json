{
  "name": "@airshade/riot-client",
  "version": "2.0.0",
  "description": "Thin riot-gateway transport for Airshade — forwards Riot requests to the gateway in PATH mode and returns raw payloads. No API key, no client-side rate limiting, no schema validation.",
  "author": "Airshade",
  "contributors": [
    "Gabriel-Passoss (original samira author)"
  ],
  "homepage": "https://github.com/airshadeSolutions/riot-client#readme",
  "bugs": "https://github.com/airshadeSolutions/riot-client/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/airshadeSolutions/riot-client.git"
  },
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint:prettier": "prettier -c .",
    "format:prettier": "prettier -w ."
  },
  "keywords": [
    "league-of-legends",
    "lol",
    "api",
    "typescript",
    "riot-gateway"
  ],
  "dependencies": {},
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.4",
    "@types/node": "^20.8.0",
    "@vitest/ui": "^1.0.0",
    "prettier": "^3.6.2",
    "semantic-release": "^24.2.7",
    "typescript": "^5.2.2",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
